generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  EMPLOYEE
}

enum MovementType {
  IN
  OUT
}

enum MovementSource {
  MANUAL
  QRCODE
}

enum PackageType {
  CX
  PCT
}

model Adega {
  id             String     @id @default(cuid())
  name           String
  /// Importação em lote de produtos (planilha) é um recurso pago, liberado manualmente
  /// por adega — não é auto-habilitado no cadastro self-service.
  importEnabled  Boolean    @default(false)
  /// Conta fica travada (sem acesso ao app) até o pagamento ser confirmado e a conta
  /// ser aprovada manualmente. Cadastro self-service sempre nasce com approved = false.
  approved       Boolean    @default(false)
  createdAt      DateTime   @default(now())
  users          User[]
  products       Product[]
  movements      Movement[]
  pedidos        Pedido[]
  counters       Counter[]
}

/// Contador atômico por adega (código de produto, número de pedido por tipo, etc).
/// O upsert com increment é uma única instrução UPDATE no Postgres — o próprio banco
/// serializa concorrência na mesma linha, sem precisar de lock explícito na aplicação.
model Counter {
  adegaId String
  adega   Adega  @relation(fields: [adegaId], references: [id])
  scope   String
  value   Int    @default(0)

  @@id([adegaId, scope])
}

model User {
  id           String     @id @default(cuid())
  adegaId      String
  adega        Adega      @relation(fields: [adegaId], references: [id])
  name         String
  email        String     @unique
  passwordHash String
  role         Role
  createdAt    DateTime   @default(now())
  movements    Movement[] @relation("MovementCreatedBy")
  pedidos      Pedido[]   @relation("PedidoCreatedBy")
  pedidosCancelados Pedido[] @relation("PedidoCancelledBy")
}

model Product {
  id            String     @id @default(cuid())
  adegaId       String
  adega         Adega      @relation(fields: [adegaId], references: [id])
  code          String
  barcode       String?
  name          String
  category      String
  unit          String
  /// Dinheiro nunca em Float — ponto flutuante binário não representa centavos com
  /// exatidão e o erro acumula em relatórios. Decimal(12,2) mapeia pra numeric no Postgres.
  costPrice     Decimal    @db.Decimal(12, 2)
  salePrice     Decimal    @db.Decimal(12, 2)
  /// Quantidade é sempre inteira (regra de negócio validada em toda a aplicação) — Int
  /// em vez de Float evita que um bug de arredondamento em algum lugar grave fração de unidade.
  currentStock  Int        @default(0)
  minStockAlert Int?
  packageType   PackageType?
  unitsPerPackage Int?
  createdAt     DateTime   @default(now())
  movements     Movement[]

  @@index([adegaId])
  @@unique([adegaId, code])
  @@unique([adegaId, barcode])
}

model Pedido {
  id              String       @id @default(cuid())
  adegaId         String
  adega           Adega        @relation(fields: [adegaId], references: [id])
  type            MovementType @default(OUT)
  number          Int
  totalValue      Decimal      @db.Decimal(12, 2)
  createdAt       DateTime     @default(now())
  createdByUserId String
  createdByUser   User         @relation("PedidoCreatedBy", fields: [createdByUserId], references: [id])
  cancelledAt     DateTime?
  cancelledByUserId String?
  cancelledByUser User?        @relation("PedidoCancelledBy", fields: [cancelledByUserId], references: [id])
  items           Movement[]

  @@index([adegaId])
  @@index([adegaId, type, createdAt])
  @@unique([adegaId, type, number])
}

model Movement {
  id              String         @id @default(cuid())
  adegaId         String
  adega           Adega          @relation(fields: [adegaId], references: [id])
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  type            MovementType
  quantity        Int
  unitValue       Decimal        @db.Decimal(12, 2)
  totalValue      Decimal        @db.Decimal(12, 2)
  createdAt       DateTime       @default(now())
  createdByUserId String
  createdByUser   User           @relation("MovementCreatedBy", fields: [createdByUserId], references: [id])
  source          MovementSource @default(MANUAL)
  pedidoId        String?
  pedido          Pedido?        @relation(fields: [pedidoId], references: [id])

  @@index([adegaId])
  @@index([productId])
  @@index([createdAt])
  @@index([pedidoId])
  @@index([adegaId, type, createdAt])
}
